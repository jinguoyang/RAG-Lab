# RAG-Lab 后端本地配置示例
# 复制为 .env 后按本机环境调整；.env 不应提交到 Git。

RAG_LAB_APP_NAME=RAG-Lab API
RAG_LAB_APP_VERSION=0.1.0
RAG_LAB_ENVIRONMENT=local
RAG_LAB_API_V1_PREFIX=/api/v1
RAG_LAB_BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
RAG_LAB_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/rag-platform
RAG_LAB_DEV_AUTH_ENABLED=true
RAG_LAB_DEV_DEFAULT_USERNAME=admin
RAG_LAB_DEV_DEFAULT_SECURITY_LEVEL=public

# 对象存储配置：本地默认 metadata 只记录对象引用；接入 MinIO 时改为 minio。
# 兼容 env_info.txt 中的 OBJECT_STORAGE_PROVIDER / MINIO_BUCKET 写法。
RAG_LAB_STORAGE_BACKEND=metadata
RAG_LAB_STORAGE_BUCKET=rag-lab-source
RAG_LAB_STORAGE_OBJECT_PREFIX=dev
RAG_LAB_MINIO_ENDPOINT=127.0.0.1:9000
RAG_LAB_MINIO_ACCESS_KEY=minioadmin
RAG_LAB_MINIO_SECRET_KEY=minioadmin
RAG_LAB_MINIO_SECURE=false

# E5 Provider 配置：默认 local / identity 可本地验证；改为真实后端时需补齐地址和凭据。
RAG_LAB_EMBEDDING_PROVIDER=local
RAG_LAB_EMBEDDING_ENDPOINT=
RAG_LAB_EMBEDDING_API_KEY=
RAG_LAB_EMBEDDING_MODEL=text-embedding-3-small
RAG_LAB_DENSE_RETRIEVAL_PROVIDER=local
RAG_LAB_MILVUS_URI=
RAG_LAB_MILVUS_TOKEN=
RAG_LAB_MILVUS_COLLECTION=rag_chunk_embeddings
RAG_LAB_SPARSE_RETRIEVAL_PROVIDER=local
RAG_LAB_OPENSEARCH_HOSTS=
RAG_LAB_OPENSEARCH_USERNAME=
RAG_LAB_OPENSEARCH_PASSWORD=
RAG_LAB_OPENSEARCH_INDEX=rag_chunks
RAG_LAB_GRAPH_RETRIEVAL_PROVIDER=local
RAG_LAB_NEO4J_URI=
RAG_LAB_NEO4J_USERNAME=
RAG_LAB_NEO4J_PASSWORD=
RAG_LAB_NEO4J_DATABASE=
RAG_LAB_LLM_PROVIDER=local
RAG_LAB_LLM_ENDPOINT=
RAG_LAB_LLM_API_KEY=
RAG_LAB_LLM_MODEL=local-rag-lab
RAG_LAB_RERANK_PROVIDER=identity
RAG_LAB_RERANK_ENDPOINT=
RAG_LAB_RERANK_API_KEY=
RAG_LAB_PROVIDER_TOP_K=5

# 172.18.30.x 开发环境示例：
# RAG_LAB_STORAGE_BACKEND=minio
# RAG_LAB_STORAGE_BUCKET=rag-lab
# RAG_LAB_STORAGE_OBJECT_PREFIX=dev
# RAG_LAB_MINIO_ENDPOINT=172.18.30.95:9000
# RAG_LAB_MINIO_ACCESS_KEY=minioadmin
# RAG_LAB_MINIO_SECRET_KEY=minioadmin
# RAG_LAB_MINIO_SECURE=false
# RAG_LAB_SPARSE_RETRIEVAL_PROVIDER=opensearch
# RAG_LAB_OPENSEARCH_HOSTS=http://172.18.30.95:9200
# RAG_LAB_OPENSEARCH_INDEX=rag-lab
# RAG_LAB_GRAPH_RETRIEVAL_PROVIDER=neo4j
# RAG_LAB_NEO4J_URI=bolt://172.18.30.95:7687
# RAG_LAB_NEO4J_USERNAME=neo4j
# RAG_LAB_NEO4J_PASSWORD=test1234
