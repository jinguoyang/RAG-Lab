# RAG-Lab 后端本地配置示例
# 复制为 .env 后按本机环境调整；.env 不应提交到 Git。

RAG_LAB_APP_NAME=RAG-Lab API
RAG_LAB_APP_VERSION=0.1.0
RAG_LAB_ENVIRONMENT=local
RAG_LAB_API_V1_PREFIX=/api/v1
RAG_LAB_BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
RAG_LAB_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/rag-platform
RAG_LAB_DEV_AUTH_ENABLED=true
RAG_LAB_DEV_DEFAULT_USERNAME=admin
RAG_LAB_DEV_DEFAULT_SECURITY_LEVEL=public
